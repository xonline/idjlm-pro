# IDJLM Pro — API Keys
# Copy this file to .env and fill in your keys

# AI Model — choose one: claude, gemini, ollama, openrouter
AI_MODEL=gemini

# Required for Claude — get your key at https://console.anthropic.com/
ANTHROPIC_API_KEY=

# Required for Gemini — get your free key at https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Optional — OpenRouter (access many models via one key)
# Get key at https://openrouter.ai/ — free models available
OPENROUTER_API_KEY=
# OPENROUTER_MODEL=google/gemini-2.0-flash-exp:free

# Optional — Local Ollama (no key needed)
# OLLAMA_MODEL=qwen3:1.7b

# Optional — Spotify metadata enrichment (year, artist, title lookup)
# Get credentials at: https://developer.spotify.com/dashboard
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# Batch size for AI classification (1-20 tracks per API call)
CLASSIFY_BATCH_SIZE=10

# Flask config (leave defaults unless you need to change port)
FLASK_PORT=5050
FLASK_DEBUG=false
